# Local development when the frontend runs directly on the host machine.
BACKEND_API_URL=http://localhost:3000

# Docker: backend running on the host machine from inside the frontend container.
# BACKEND_API_URL=http://host.docker.internal:3000

# Docker: backend running in the same Docker network.
# BACKEND_API_URL=http://backend:3000

# Deployed backend.
# BACKEND_API_URL=https://api.example.com

NEXT_PUBLIC_API_URL=/api
